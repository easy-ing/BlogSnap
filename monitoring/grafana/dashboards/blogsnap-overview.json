{
  "id": null,
  "uid": "blogsnap-overview",
  "title": "BlogSnap Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["blogsnap", "day9"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Requests / sec",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(blogsnap_http_requests_total[1m]))",
          "legendFormat": "rps",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP 5xx / sec",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(blogsnap_http_requests_total{status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx rps",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP p95 Latency (s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(blogsnap_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Jobs Processed (by outcome)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum by (outcome) (rate(blogsnap_jobs_processed_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    }
  ],
  "annotations": {"list": []},
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"}
}
