OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-mini
DATABASE_URL=postgresql+psycopg://blogsnap:blogsnap@localhost:55432/blogsnap
WORKER_POLL_SECONDS=3
WORKER_BATCH_SIZE=10
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true
AUTH_SECRET_KEY=change-me-dev-secret
AUTH_TOKEN_EXP_MINUTES=120
AUTH_REFRESH_TOKEN_EXP_MINUTES=20160
ASSET_MAX_BYTES=5242880
ASSET_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/gif
GRAFANA_ADMIN_PASSWORD=admin
ALERT_WEBHOOK_PORT=5001
ALERT_WEBHOOK_LOG_PATH=/data/alerts.jsonl
ALERT_FORWARD_WEBHOOK_URL=
ALERT_FORWARD_WEBHOOK_URL_WARNING=
ALERT_FORWARD_WEBHOOK_URL_CRITICAL=
ALERT_FORWARD_TIMEOUT_SECONDS=5
ALERT_PAGERDUTY_EVENTS_URL=https://events.pagerduty.com/v2/enqueue
ALERT_PAGERDUTY_ROUTING_KEY=
ALERT_PAGERDUTY_ENABLED_CHANNELS=critical
ALERT_SILENCE_WINDOW_SECONDS=90
ALERT_SILENCE_WINDOW_WARNING_SECONDS=90
ALERT_SILENCE_WINDOW_CRITICAL_SECONDS=90
ALERT_SILENCE_WINDOW_GENERIC_SECONDS=90
WORKER_PUBLISH_MODE=mock
WORKER_MOCK_PUBLISH_BASE_URL=https://example.com/mock-post
WORDPRESS_BASE_URL=https://yourblog.com
WORDPRESS_USERNAME=your_username
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
TISTORY_API_URL=https://www.tistory.com/apis/post/write
TISTORY_ACCESS_TOKEN=your_tistory_access_token
TISTORY_BLOG_NAME=your_tistory_blog_name
WORKER_PUBLISH_DEFAULT_TAGS=자동화,AI,블로그

BLOG_PROVIDER=wordpress
BLOG_BASE_URL=https://yourblog.com
BLOG_USERNAME=your_username
BLOG_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Optional defaults
DEFAULT_CATEGORY=
DEFAULT_TAGS=자동화,AI,블로그
